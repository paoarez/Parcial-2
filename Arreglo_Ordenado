import java.util.Random;
import java.util.Arrays;

public class ArregloEstadisticas {

    public static void main(String[] args) {

        // Constructor 1
        Arreglo arreglo1 = new Arreglo(10);
        arreglo1.llenarAleatorio(20);
        System.out.println("Arreglo original (desordenad)");
        System.out.println("Arreglo 1: " + arreglo1);
        arreglo1.bubbles(arreglo1.values);
        System.out.println("Arreglo 1 ordenado: " + arreglo1);
        
        // Constructor 2
        /*int[] numeros = {5, 8, 2, 9, 1};
        Arreglo arreglo2 = new Arreglo(numeros);
        System.out.println("Arreglo 2: " + arreglo2);*/
        
    }
}

class Arreglo {

    public int[] values;

    public Arreglo(int cantidad) {
        values = new int[cantidad];
    }
    
    public Arreglo(int[] values) {
        this.values = values;
    }
    
    public void bubbles(int[] datos) {
        for (int pasadas = 1; pasadas < datos.length; pasadas++) {
            for (int i = 0; i < datos.length - 1; i++) {
                if (datos[i] > datos[i + 1]) {
                    int temp = datos[i];
                    datos[i] = datos[i + 1];
                    datos[i + 1] = temp;
                }
            }
        }
    }

    public void selectionSort(int[] datos) {
        int n = datos.length;

        for (int i = 0; i < n - 1; i++) {
            int indiceMinimo = i;

            for (int j = i + 1; j < n; j++) {
                if (datos[j] < datos[indiceMinimo]) {
                    indiceMinimo = j;
                }
            }

            int temp = datos[indiceMinimo];
            datos[indiceMinimo] = datos[i];
            datos[i] = temp;
        }
    }

    // Método para llenar con números aleatorios
    public void llenarAleatorio(int limite) {
        Random random = new Random();
        for (int i = 0; i < values.length; i++) {
            values[i] = random.nextInt(limite);
        }
    }

    // Método para calcular el promedio
    public double promedio() {
        int suma = 0;
        for (int i = 0; i < values.length; i++) {
            suma += values[i];
        }
        return (double) suma / values.length;
    }

    public int maximo() {
        int max = values[0];
        for (int i = 1; i < values.length; i++) {
            if (values[i] > max) {
                max = values[i];
            }
        }
        return max;
    }

    // Método para obtener el valor mínimo
    public int minimo() {
        int min = values[0];
        for (int i = 1; i < values.length; i++) {
            if (values[i] < min) {
                min = values[i];
            }
        }
        return min;
    }

    public String toString() {
        return Arrays.toString(values);
    }
}
